#!/bin/bash
# trmm-frontend-build
# Build a git branch from a managed repo and deploy it as a named frontend version.
#
# Usage:
#   trmm-frontend-build                       # Build default repo, current branch
#   trmm-frontend-build --repo myrepo         # Build from named repo
#   trmm-frontend-build --name foo            # Custom version label
#   trmm-frontend-build --activate            # Make it live immediately
set -e

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
source "$SCRIPT_DIR/yolo.conf"

# Parse arguments
VERSION_NAME=""
REPO_NAME=""
ACTIVATE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --name)
            VERSION_NAME="$2"
            shift 2
            ;;
        --repo)
            REPO_NAME="$2"
            shift 2
            ;;
        --activate)
            ACTIVATE=true
            shift
            ;;
        *)
            echo "Unknown option: $1"
            echo "Usage: trmm-frontend-build [--repo <name>] [--name <name>] [--activate]"
            exit 1
            ;;
    esac
done

# Resolve which repo to build from
if [ -n "$REPO_NAME" ]; then
    FRONTEND_SRC="$REPOS_DIR/$REPO_NAME"
    if [ ! -d "$FRONTEND_SRC" ]; then
        echo "Error: Repo '$REPO_NAME' not found in $REPOS_DIR"
        echo "Available repos:"
        ls -1 "$REPOS_DIR" 2>/dev/null || echo "  (none)"
        exit 1
    fi
elif [ -d ".git" ] && [[ "$(pwd)" == "$REPOS_DIR"/* ]]; then
    FRONTEND_SRC="$(git rev-parse --show-toplevel)"
    REPO_NAME="$(basename "$FRONTEND_SRC")"
else
    REPO_NAME="$DEFAULT_REPO_NAME"
    FRONTEND_SRC="$REPOS_DIR/$REPO_NAME"
    if [ ! -d "$FRONTEND_SRC" ]; then
        echo "Error: Default repo '$REPO_NAME' not found. Run install.sh or trmm-frontend-repo add."
        exit 1
    fi
fi

# Check prerequisites
if [ ! -d "$VERSIONS_DIR" ]; then
    echo "Error: $VERSIONS_DIR does not exist. Run install.sh first."
    exit 1
fi

if [ ! -f "$ENV_CONFIG_SRC" ]; then
    echo "Error: $ENV_CONFIG_SRC not found. Cannot copy env-config.js."
    exit 1
fi

# Determine version name from git branch if not provided
if [ -z "$VERSION_NAME" ]; then
    cd "$FRONTEND_SRC"
    BRANCH=$(git rev-parse --abbrev-ref HEAD | sed 's/\//-/g')

    # If multiple repos exist, prefix with repo name to avoid collisions
    REPO_COUNT=$(ls -1d "$REPOS_DIR"/*/ 2>/dev/null | wc -l)
    if [ "$REPO_COUNT" -le 1 ]; then
        VERSION_NAME="$BRANCH"
    else
        VERSION_NAME="${REPO_NAME}--${BRANCH}"
    fi
fi

VERSION_PATH="$VERSIONS_DIR/$VERSION_NAME"

echo "========================================"
echo "Frontend Build & Deploy"
echo "========================================"
echo "Repo:     $REPO_NAME ($FRONTEND_SRC)"
echo "Version:  $VERSION_NAME"
echo "Target:   $VERSION_PATH"
echo "Activate: $ACTIVATE"
echo "========================================"

# Ensure node_modules is up to date
cd "$FRONTEND_SRC"
if [ ! -d "node_modules" ] || [ "package-lock.json" -nt "node_modules/.package-lock.json" ]; then
    echo ""
    echo "Running npm install..."
    npm install
fi

# Build
echo ""
echo "Running npm run build..."
npm run build

# Deploy to versions directory
if [ -d "$VERSION_PATH" ]; then
    echo "Removing existing version: $VERSION_NAME"
    rm -rf "$VERSION_PATH"
fi

mkdir -p "$VERSION_PATH"
cp -r "$FRONTEND_SRC/dist/"* "$VERSION_PATH/"

# Copy env-config.js from backup
cp "$ENV_CONFIG_SRC" "$VERSION_PATH/env-config.js"

echo "Deployed to: $VERSION_PATH"

# Optionally activate
if [ "$ACTIVATE" = true ]; then
    ln -sfn "$VERSION_PATH" "${DIST_SYMLINK}.tmp"
    mv -T "${DIST_SYMLINK}.tmp" "$DIST_SYMLINK"
    echo "Activated version: $VERSION_NAME"
fi

echo ""
echo "Done. Version '$VERSION_NAME' is ready."
if [ "$ACTIVATE" = false ]; then
    echo "To make it live, use: trmm-frontend-versions switch $VERSION_NAME"
    echo "Or right-click the version number in the dashboard."
fi
